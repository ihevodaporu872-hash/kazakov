<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="app.diagrams.net" modified="2026-03-11T12:00:00.000Z" type="device">
  <diagram id="heating-calc-flow" name="Логика расчёта отопления">
    <mxGraphModel dx="2200" dy="2800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="4000" pageHeight="6000" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- ========================================== -->
        <!-- ЗАГОЛОВОК -->
        <!-- ========================================== -->
        <mxCell id="title" value="&lt;b&gt;ЛОГИКА РАСЧЁТА СИСТЕМЫ ОТОПЛЕНИЯ&lt;/b&gt;&lt;br&gt;Полная блок-схема алгоритма калькулятора" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=20;fontColor=#1a1a2e;" vertex="1" parent="1">
          <mxGeometry x="600" y="20" width="800" height="60" as="geometry"/>
        </mxCell>

        <!-- ========================================== -->
        <!-- БЛОК 1: ИСХОДНЫЕ ДАННЫЕ (голубой) -->
        <!-- ========================================== -->
        <mxCell id="b1_group" value="" style="group" vertex="1" connectable="0" parent="1">
          <mxGeometry x="40" y="100" width="580" height="620" as="geometry"/>
        </mxCell>
        <mxCell id="b1_bg" value="" style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;arcSize=6;" vertex="1" parent="b1_group">
          <mxGeometry width="580" height="620" as="geometry"/>
        </mxCell>
        <mxCell id="b1_title" value="&lt;b&gt;БЛОК 1: ИСХОДНЫЕ ДАННЫЕ&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;fontSize=14;fontColor=#1a1a2e;" vertex="1" parent="b1_group">
          <mxGeometry x="10" y="10" width="560" height="30" as="geometry"/>
        </mxCell>

        <!-- Входные параметры -->
        <mxCell id="b1_inputs" value="&lt;b&gt;Входные параметры:&lt;/b&gt;&lt;br&gt;• Кол-во окон = кол-во приборов (windowCount)&lt;br&gt;• Расход тепла → heatLoad_W (конверт. в Вт)&lt;br&gt;• Высота простенка (wallHeight_mm)&lt;br&gt;• Высота стяжки (screedHeight_mm, по умолч. 100)&lt;br&gt;• Температурный график (schedule)&lt;br&gt;• t внутр. воздуха (tInside, по умолч. 20°C)" style="rounded=1;whiteSpace=wrap;html=1;align=left;spacingLeft=10;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;" vertex="1" parent="b1_group">
          <mxGeometry x="20" y="50" width="260" height="160" as="geometry"/>
        </mxCell>

        <!-- Параметры проекта -->
        <mxCell id="b1_project" value="&lt;b&gt;Параметры проекта:&lt;/b&gt;&lt;br&gt;• Этажи, пар стояков (riserPairs)&lt;br&gt;• Выходов гребёнок (manifoldOutputs)&lt;br&gt;• Зон отопления (heatingZones)&lt;br&gt;• Квартир (всего, apartments)&lt;br&gt;• Высота этажа (floorHeight_mm)&lt;br&gt;• Толщина изоляции (insulationThickness_mm)" style="rounded=1;whiteSpace=wrap;html=1;align=left;spacingLeft=10;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;" vertex="1" parent="b1_group">
          <mxGeometry x="300" y="50" width="260" height="160" as="geometry"/>
        </mxCell>

        <!-- Дополнительные параметры -->
        <mxCell id="b1_extra" value="&lt;b&gt;Параметры разводки:&lt;/b&gt;&lt;br&gt;• Тип разводки PEX: radial / series&lt;br&gt;• Длина коридора (corridorLength_m)&lt;br&gt;• Комнат/квартиру (roomsPerApartment)&lt;br&gt;• Квартир/этаж (apartmentsPerFloor)" style="rounded=1;whiteSpace=wrap;html=1;align=left;spacingLeft=10;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;" vertex="1" parent="b1_group">
          <mxGeometry x="20" y="230" width="260" height="110" as="geometry"/>
        </mxCell>

        <!-- Формулы блока 1 -->
        <mxCell id="b1_formulas" value="&lt;b&gt;Формулы:&lt;/b&gt;&lt;hr&gt;&lt;b&gt;Конвертация:&lt;/b&gt;&lt;br&gt;kW → ×1000 | Гкал/ч → ×1 163 000 | МВт → ×1 000 000&lt;br&gt;&lt;br&gt;&lt;b&gt;Расчёт Δt:&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#0000CC&quot;&gt;Δt = (t_подачи + t_обратки) / 2 − t_внутр&lt;/font&gt;&lt;br&gt;&lt;br&gt;Пример: 80/60, t=20 → Δt = (80+60)/2 − 20 = &lt;b&gt;50°C&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=left;spacingLeft=10;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="b1_group">
          <mxGeometry x="20" y="360" width="540" height="140" as="geometry"/>
        </mxCell>

        <!-- Выходы блока 1 -->
        <mxCell id="b1_outputs" value="&lt;b&gt;ВЫХОД →&lt;/b&gt; windowCount, heatLoad_W, Δt, windows[], schedule, wallHeight_mm, screedHeight_mm" style="rounded=1;whiteSpace=wrap;html=1;align=center;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;fontStyle=1;" vertex="1" parent="b1_group">
          <mxGeometry x="20" y="520" width="540" height="40" as="geometry"/>
        </mxCell>

        <!-- ========================================== -->
        <!-- БЛОК 2: ПОДБОР ПРИБОРОВ (оранжевый) -->
        <!-- ========================================== -->
        <mxCell id="b2_group" value="" style="group" vertex="1" connectable="0" parent="1">
          <mxGeometry x="660" y="100" width="700" height="900" as="geometry"/>
        </mxCell>
        <mxCell id="b2_bg" value="" style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;arcSize=4;" vertex="1" parent="b2_group">
          <mxGeometry width="700" height="900" as="geometry"/>
        </mxCell>
        <mxCell id="b2_title" value="&lt;b&gt;БЛОК 2: ПОДБОР ПРИБОРОВ ОТОПЛЕНИЯ&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;fontSize=14;fontColor=#1a1a2e;" vertex="1" parent="b2_group">
          <mxGeometry x="10" y="10" width="680" height="30" as="geometry"/>
        </mxCell>

        <!-- Шаг 2.1 - Удельная мощность -->
        <mxCell id="b2_step1" value="&lt;b&gt;2.1. Удельная мощность Q_м&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;font color=&quot;#0000CC&quot;&gt;Q_м = Q_общ / (Σ ширин_окон_м − N × 0.2)&lt;/font&gt;&lt;br&gt;&lt;br&gt;Результат: Вт/м — мощность на 1 п.м. прибора" style="rounded=1;whiteSpace=wrap;html=1;align=left;spacingLeft=10;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;" vertex="1" parent="b2_group">
          <mxGeometry x="20" y="50" width="320" height="100" as="geometry"/>
        </mxCell>

        <!-- Шаг 2.2 - Длина прибора -->
        <mxCell id="b2_step2" value="&lt;b&gt;2.2. Длина прибора&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;font color=&quot;#0000CC&quot;&gt;deviceLength = ширина_окна − 200 мм&lt;/font&gt;&lt;br&gt;&lt;br&gt;Округление вниз до стандартных:&lt;br&gt;400, 500, 600 … 1800, 2000, 2300, 2600, 3000" style="rounded=1;whiteSpace=wrap;html=1;align=left;spacingLeft=10;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;" vertex="1" parent="b2_group">
          <mxGeometry x="360" y="50" width="320" height="100" as="geometry"/>
        </mxCell>

        <!-- Шаг 2.3 - Высота прибора -->
        <mxCell id="b2_step3" value="&lt;b&gt;2.3. Высота прибора&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=center;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;fontStyle=1;" vertex="1" parent="b2_group">
          <mxGeometry x="20" y="170" width="660" height="30" as="geometry"/>
        </mxCell>

        <!-- Ветвление по типу -->
        <mxCell id="b2_diamond" value="Тип прибора?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="b2_group">
          <mxGeometry x="260" y="210" width="160" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="b2_h_inFloor" value="&lt;b&gt;Внутрипольные&lt;/b&gt;&lt;br&gt;h = 150 мм (фикс.)" style="rounded=1;whiteSpace=wrap;html=1;align=center;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;" vertex="1" parent="b2_group">
          <mxGeometry x="20" y="220" width="180" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="b2_h_wall" value="&lt;b&gt;Настенные / Напольные&lt;/b&gt;&lt;br&gt;h = простенок − стяжка − 200&lt;br&gt;(мин. 300 мм)" style="rounded=1;whiteSpace=wrap;html=1;align=center;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;" vertex="1" parent="b2_group">
          <mxGeometry x="480" y="215" width="200" height="50" as="geometry"/>
        </mxCell>

        <!-- EN 442 -->
        <mxCell id="b2_en442" value="&lt;b&gt;2.4. Пересчёт мощности по EN 442&lt;/b&gt;&lt;br&gt;&lt;br&gt;Каталог даёт Q при Δt_кат = 50°C.&lt;br&gt;Фактическая мощность:&lt;br&gt;&lt;br&gt;&lt;font color=&quot;#CC0000&quot; size=&quot;3&quot;&gt;&lt;b&gt;Q_факт = Q_кат × (Δt_факт / 50)^1.3&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;br&gt;Показатель &lt;b&gt;1.3&lt;/b&gt; — стандарт EN 442 для панельных радиаторов" style="rounded=1;whiteSpace=wrap;html=1;align=center;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="b2_group">
          <mxGeometry x="20" y="290" width="660" height="110" as="geometry"/>
        </mxCell>

        <!-- Алгоритм подбора панельных -->
        <mxCell id="b2_algo_title" value="&lt;b&gt;2.5. АЛГОРИТМ ПОДБОРА ПАНЕЛЬНЫХ РАДИАТОРОВ&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;fontSize=12;fontColor=#CC0000;" vertex="1" parent="b2_group">
          <mxGeometry x="20" y="415" width="660" height="25" as="geometry"/>
        </mxCell>

        <!-- Flowchart подбора -->
        <mxCell id="b2_start" value="Начало:&lt;br&gt;для каждого окна" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="b2_group">
          <mxGeometry x="30" y="450" width="120" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="b2_stdlen" value="stdLen =&lt;br&gt;nearestStdLengthDown&lt;br&gt;(deviceLength)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;" vertex="1" parent="b2_group">
          <mxGeometry x="170" y="450" width="130" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="b2_type_loop" value="Тип: 11→21s→22→33&lt;br&gt;(от тонкого к толстому)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="b2_group">
          <mxGeometry x="320" y="450" width="140" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="b2_catalog" value="Q_кат =&lt;br&gt;catalog[тип][h][stdLen]&lt;br&gt;Q_факт = Q_кат×(Δt/50)^1.3" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;" vertex="1" parent="b2_group">
          <mxGeometry x="480" y="450" width="160" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="b2_check" value="Q_факт ≥&lt;br&gt;Q_треб × 0.95?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="b2_group">
          <mxGeometry x="370" y="520" width="130" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="b2_yes" value="ДА → берём&lt;br&gt;этот тип" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;fontStyle=1;" vertex="1" parent="b2_group">
          <mxGeometry x="530" y="530" width="100" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="b2_no" value="НЕТ →&lt;br&gt;след. тип" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" vertex="1" parent="b2_group">
          <mxGeometry x="230" y="535" width="90" height="35" as="geometry"/>
        </mxCell>

        <mxCell id="b2_fallback" value="Все типы пройдены →&lt;br&gt;берём тип 33 (максимальный)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" vertex="1" parent="b2_group">
          <mxGeometry x="30" y="530" width="180" height="40" as="geometry"/>
        </mxCell>

        <!-- Стрелки подбора -->
        <mxCell id="b2_a1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" source="b2_start" target="b2_stdlen" parent="b2_group">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="b2_a2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" source="b2_stdlen" target="b2_type_loop" parent="b2_group">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="b2_a3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" source="b2_type_loop" target="b2_catalog" parent="b2_group">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="b2_a4" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" source="b2_catalog" target="b2_check" parent="b2_group">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="b2_a5" value="Да" style="edgeStyle=orthogonalEdgeStyle;rounded=1;fontColor=#006600;" edge="1" source="b2_check" target="b2_yes" parent="b2_group">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="b2_a6" value="Нет" style="edgeStyle=orthogonalEdgeStyle;rounded=1;fontColor=#CC0000;" edge="1" source="b2_check" target="b2_no" parent="b2_group">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="b2_a7" style="edgeStyle=orthogonalEdgeStyle;rounded=1;dashed=1;" edge="1" source="b2_no" target="b2_type_loop" parent="b2_group">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Единая высота -->
        <mxCell id="b2_unified" value="&lt;b&gt;2.7. Единая высота (findBestUnifiedHeight)&lt;/b&gt;&lt;br&gt;&lt;br&gt;Цель: одна высота для всех приборов → эстетика.&lt;br&gt;&lt;br&gt;1. Собрать все доступные высоты ≤ maxHeight&lt;br&gt;2. Для каждой h: определить мин. тип для каждого окна&lt;br&gt;3. &lt;font color=&quot;#0000CC&quot;&gt;score = maxTypeIdx × 100 + failCount × 1000&lt;/font&gt;&lt;br&gt;4. Выбрать h с минимальной оценкой" style="rounded=1;whiteSpace=wrap;html=1;align=left;spacingLeft=10;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="b2_group">
          <mxGeometry x="20" y="590" width="660" height="120" as="geometry"/>
        </mxCell>

        <!-- Подбор конвекторов -->
        <mxCell id="b2_conv" value="&lt;b&gt;2.6. Внутрипольные конвекторы&lt;/b&gt;&lt;br&gt;&lt;br&gt;Подбор по &lt;b&gt;удельной мощности (Вт/м)&lt;/b&gt;:&lt;br&gt;1. Глубина: 90/110/130/180/240/300 мм&lt;br&gt;2. Тип: natural (без вент.) / fan (с вент.)&lt;br&gt;3. Q_факт_Вт_м = correctPower(Q_кат_Вт_м, 50, Δt)&lt;br&gt;4. Q_треб = powerPerMeter × (deviceLen / 1000)" style="rounded=1;whiteSpace=wrap;html=1;align=left;spacingLeft=10;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;" vertex="1" parent="b2_group">
          <mxGeometry x="20" y="730" width="660" height="110" as="geometry"/>
        </mxCell>

        <!-- Выход блока 2 -->
        <mxCell id="b2_output" value="&lt;b&gt;ВЫХОД →&lt;/b&gt; perWindow[] = { deviceName, devLen, devHeight, powerReq, powerFact, panelType }" style="rounded=1;whiteSpace=wrap;html=1;align=center;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;fontStyle=1;" vertex="1" parent="b2_group">
          <mxGeometry x="20" y="850" width="660" height="35" as="geometry"/>
        </mxCell>

        <!-- ========================================== -->
        <!-- БЛОК 3: ТЕРМОГОЛОВКИ И КЛАПАНЫ (зелёный) -->
        <!-- ========================================== -->
        <mxCell id="b3_group" value="" style="group" vertex="1" connectable="0" parent="1">
          <mxGeometry x="1400" y="100" width="480" height="350" as="geometry"/>
        </mxCell>
        <mxCell id="b3_bg" value="" style="rounded=1;whiteSpace=wrap;fillColor=#d5e8d4;strokeColor=#82b366;arcSize=6;" vertex="1" parent="b3_group">
          <mxGeometry width="480" height="350" as="geometry"/>
        </mxCell>
        <mxCell id="b3_title" value="&lt;b&gt;БЛОК 3: ТЕРМОГОЛОВКИ И КЛАПАНЫ&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;fontSize=14;fontColor=#1a1a2e;" vertex="1" parent="b3_group">
          <mxGeometry x="10" y="10" width="460" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="b3_thermo" value="&lt;b&gt;Термоголовки (×windowCount):&lt;/b&gt;&lt;br&gt;• Danfoss RA 2991 (встр. датчик, 5-26°C)&lt;br&gt;• Danfoss с выносным датчиком (2 м)&lt;br&gt;• Oventrop Uni LH (встр. датчик, M30×1.5)&lt;br&gt;• Без термоголовки (ручной маховичок)&lt;br&gt;&lt;br&gt;&lt;i&gt;Для внутрипольных → рекомендован выносной&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=left;spacingLeft=10;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;" vertex="1" parent="b3_group">
          <mxGeometry x="20" y="50" width="440" height="130" as="geometry"/>
        </mxCell>

        <mxCell id="b3_valve" value="&lt;b&gt;Регулирующие клапаны (×windowCount):&lt;/b&gt;&lt;br&gt;• В составе прибора (included)&lt;br&gt;• Danfoss RA-N DN15, прямой&lt;br&gt;• Oventrop AV9 DN15, угловой&lt;br&gt;• IMI Eclipse с преднастройкой DN15-20" style="rounded=1;whiteSpace=wrap;html=1;align=left;spacingLeft=10;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;" vertex="1" parent="b3_group">
          <mxGeometry x="20" y="200" width="440" height="100" as="geometry"/>
        </mxCell>

        <mxCell id="b3_output" value="&lt;b&gt;ВЫХОД →&lt;/b&gt; thermoHead, valve" style="rounded=1;whiteSpace=wrap;html=1;align=center;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;fontStyle=1;" vertex="1" parent="b3_group">
          <mxGeometry x="20" y="310" width="440" height="30" as="geometry"/>
        </mxCell>

        <!-- ========================================== -->
        <!-- БЛОК 4: УЗЛЫ ПОДКЛЮЧЕНИЯ (розовый) -->
        <!-- ========================================== -->
        <mxCell id="b4_group" value="" style="group" vertex="1" connectable="0" parent="1">
          <mxGeometry x="1400" y="480" width="480" height="520" as="geometry"/>
        </mxCell>
        <mxCell id="b4_bg" value="" style="rounded=1;whiteSpace=wrap;fillColor=#f8cecc;strokeColor=#b85450;arcSize=6;" vertex="1" parent="b4_group">
          <mxGeometry width="480" height="520" as="geometry"/>
        </mxCell>
        <mxCell id="b4_title" value="&lt;b&gt;БЛОК 4: УЗЛЫ ПОДКЛЮЧЕНИЯ&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;fontSize=14;fontColor=#1a1a2e;" vertex="1" parent="b4_group">
          <mxGeometry x="10" y="10" width="460" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="b4_diamond" value="Тип прибора?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="b4_group">
          <mxGeometry x="160" y="50" width="150" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="b4_inFloor" value="&lt;b&gt;Внутрипольные (inFloor):&lt;/b&gt;&lt;br&gt;• Клапан RLV DN15 — ×N&lt;br&gt;• Клапан RA-N DN15 — ×N&lt;br&gt;• Переход → PEX Ду16 — ×N компл." style="rounded=1;whiteSpace=wrap;html=1;align=left;spacingLeft=8;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;" vertex="1" parent="b4_group">
          <mxGeometry x="20" y="120" width="200" height="90" as="geometry"/>
        </mxCell>

        <mxCell id="b4_floor" value="&lt;b&gt;Напольные (floor):&lt;/b&gt;&lt;br&gt;• Клапан RLV-K DN15 — ×N&lt;br&gt;• Ниппель G1/2&quot; — ×2N&lt;br&gt;• Евроконус G1/2&quot;×PEX — ×2N&lt;br&gt;• L-трубка — ×2N" style="rounded=1;whiteSpace=wrap;html=1;align=left;spacingLeft=8;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;" vertex="1" parent="b4_group">
          <mxGeometry x="250" y="120" width="210" height="90" as="geometry"/>
        </mxCell>

        <mxCell id="b4_wall" value="&lt;b&gt;Настенные (wall):&lt;/b&gt;&lt;br&gt;• Клапан RLV-K DN15 — ×N&lt;br&gt;• Ниппель G1/2&quot; — ×2N&lt;br&gt;• Евроконус G1/2&quot;×PEX — ×2N&lt;br&gt;• L-трубка — ×2N" style="rounded=1;whiteSpace=wrap;html=1;align=left;spacingLeft=8;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;" vertex="1" parent="b4_group">
          <mxGeometry x="140" y="230" width="210" height="90" as="geometry"/>
        </mxCell>

        <mxCell id="b4_common" value="&lt;b&gt;Общие позиции (для всех типов):&lt;/b&gt;&lt;br&gt;• Воздухоотводчик (кран Маевского) DN15 — ×N&lt;br&gt;• Кронштейны: настенные ×3N / напольные ×2N&lt;br&gt;&lt;br&gt;N = windowCount (кол-во приборов)" style="rounded=1;whiteSpace=wrap;html=1;align=left;spacingLeft=10;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="b4_group">
          <mxGeometry x="20" y="340" width="440" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="b4_output" value="&lt;b&gt;ВЫХОД →&lt;/b&gt; specData[] (спецификация оборудования)" style="rounded=1;whiteSpace=wrap;html=1;align=center;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;fontStyle=1;" vertex="1" parent="b4_group">
          <mxGeometry x="20" y="440" width="440" height="30" as="geometry"/>
        </mxCell>

        <!-- ========================================== -->
        <!-- БЛОК 5: СТАЛЬНЫЕ СТОЯКИ (красный) -->
        <!-- ========================================== -->
        <mxCell id="b5_group" value="" style="group" vertex="1" connectable="0" parent="1">
          <mxGeometry x="40" y="760" width="580" height="640" as="geometry"/>
        </mxCell>
        <mxCell id="b5_bg" value="" style="rounded=1;whiteSpace=wrap;fillColor=#f8cecc;strokeColor=#b85450;arcSize=6;" vertex="1" parent="b5_group">
          <mxGeometry width="580" height="640" as="geometry"/>
        </mxCell>
        <mxCell id="b5_title" value="&lt;b&gt;БЛОК 5: СТАЛЬНЫЕ СТОЯКИ&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;fontSize=14;fontColor=#1a1a2e;" vertex="1" parent="b5_group">
          <mxGeometry x="10" y="10" width="560" height="30" as="geometry"/>
        </mxCell>

        <!-- Формула диаметра -->
        <mxCell id="b5_diam" value="&lt;b&gt;5.1. Диаметр стояка&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;font color=&quot;#CC0000&quot; size=&quot;3&quot;&gt;&lt;b&gt;d = 18.8 × √((0.86 × Q) / (ΔT × v))&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;br&gt;Q_стояк = Q_общ_кВт / (riserPairs × heatingZones)&lt;br&gt;ΔT = t_подачи − t_обратки (напр. 80−60 = 20°C)&lt;br&gt;v = 0.7 м/с (скорость теплоносителя)&lt;br&gt;&lt;br&gt;→ Округление вверх до стандартного DN:&lt;br&gt;15, 20, 25, 32, 40, 50, 65, 80, 100" style="rounded=1;whiteSpace=wrap;html=1;align=left;spacingLeft=10;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="b5_group">
          <mxGeometry x="20" y="50" width="540" height="160" as="geometry"/>
        </mxCell>

        <!-- Длина стояков -->
        <mxCell id="b5_len" value="&lt;b&gt;5.2. Длина стояков&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#0000CC&quot;&gt;L = floorHeight_м × numFloors × riserPairs × 2 × heatingZones&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=left;spacingLeft=10;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;" vertex="1" parent="b5_group">
          <mxGeometry x="20" y="225" width="540" height="50" as="geometry"/>
        </mxCell>

        <!-- Компенсаторы и НО -->
        <mxCell id="b5_comp" value="&lt;b&gt;5.3. Компенсаторы&lt;/b&gt; (через каждые 4 этажа)&lt;br&gt;&lt;font color=&quot;#0000CC&quot;&gt;комп/стояк = ceil(numFloors/4) − 1&lt;/font&gt;&lt;br&gt;total = комп/стояк × riserPairs × 2 × zones&lt;br&gt;&lt;br&gt;&lt;b&gt;5.4. Неподвижные опоры&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#0000CC&quot;&gt;НО/стояк = комп/стояк + 1&lt;/font&gt;&lt;br&gt;(только при наличии компенсаторов)" style="rounded=1;whiteSpace=wrap;html=1;align=left;spacingLeft=10;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;" vertex="1" parent="b5_group">
          <mxGeometry x="20" y="290" width="540" height="120" as="geometry"/>
        </mxCell>

        <!-- Арматура -->
        <mxCell id="b5_valves" value="&lt;b&gt;5.5-5.9. Арматура и комплектующие&lt;/b&gt;&lt;br&gt;&lt;br&gt;• Краны шаровые: riserPairs × 2 × 2 × zones (верх+низ)&lt;br&gt;• Балансир. клапаны: riserPairs × 2 × zones&lt;br&gt;• Гильзы п/п: riserPairs × 2 × zones × numFloors&lt;br&gt;• Пена п/п: ceil(гильзы / 20) баллонов&lt;br&gt;• Грунтовка: L × 0.1 кг/м.п.&lt;br&gt;• Эмаль: L × 0.15 кг/м.п.&lt;br&gt;• Воздухоотв. авто: riserPairs × 2 × zones&lt;br&gt;• Кран спускной DN15: riserPairs × 2 × zones" style="rounded=1;whiteSpace=wrap;html=1;align=left;spacingLeft=10;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;" vertex="1" parent="b5_group">
          <mxGeometry x="20" y="425" width="540" height="160" as="geometry"/>
        </mxCell>

        <mxCell id="b5_output" value="&lt;b&gt;ВЫХОД →&lt;/b&gt; riserDN, totalRiserLen, compensators, fixedSupports, materials[]" style="rounded=1;whiteSpace=wrap;html=1;align=center;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;fontStyle=1;" vertex="1" parent="b5_group">
          <mxGeometry x="20" y="600" width="540" height="30" as="geometry"/>
        </mxCell>

        <!-- ========================================== -->
        <!-- БЛОК 6: ЭТАЖНЫЕ КОЛЛЕКТОРЫ (фиолетовый) -->
        <!-- ========================================== -->
        <mxCell id="b6_group" value="" style="group" vertex="1" connectable="0" parent="1">
          <mxGeometry x="660" y="1050" width="340" height="350" as="geometry"/>
        </mxCell>
        <mxCell id="b6_bg" value="" style="rounded=1;whiteSpace=wrap;fillColor=#e1d5e7;strokeColor=#9673a6;arcSize=6;" vertex="1" parent="b6_group">
          <mxGeometry width="340" height="350" as="geometry"/>
        </mxCell>
        <mxCell id="b6_title" value="&lt;b&gt;БЛОК 6: ЭТАЖНЫЕ КОЛЛЕКТОРЫ&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;fontSize=14;fontColor=#1a1a2e;" vertex="1" parent="b6_group">
          <mxGeometry x="10" y="10" width="320" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="b6_count" value="&lt;b&gt;Количество:&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#0000CC&quot;&gt;totalManifolds = manifoldOutputs × numFloors&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=left;spacingLeft=10;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;" vertex="1" parent="b6_group">
          <mxGeometry x="20" y="50" width="300" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="b6_dn" value="&lt;b&gt;Диаметр коллектора:&lt;/b&gt;&lt;br&gt;≤ 4 отводов → DN32&lt;br&gt;5-8 отводов → DN40&lt;br&gt;&gt; 8 отводов → DN50" style="rounded=1;whiteSpace=wrap;html=1;align=left;spacingLeft=10;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;" vertex="1" parent="b6_group">
          <mxGeometry x="20" y="115" width="300" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="b6_fittings" value="&lt;b&gt;Комплектующие:&lt;/b&gt;&lt;br&gt;• Краны шаровые: totalManifolds × 2&lt;br&gt;• Тройники: totalManifolds × 2&lt;br&gt;• Присоед. фитинги PEX Ду20:&lt;br&gt;  totalManifolds × manifoldOutputs × 2" style="rounded=1;whiteSpace=wrap;html=1;align=left;spacingLeft=10;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;" vertex="1" parent="b6_group">
          <mxGeometry x="20" y="210" width="300" height="100" as="geometry"/>
        </mxCell>

        <mxCell id="b6_output" value="&lt;b&gt;ВЫХОД →&lt;/b&gt; manifolds, fittings" style="rounded=1;whiteSpace=wrap;html=1;align=center;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;fontStyle=1;" vertex="1" parent="b6_group">
          <mxGeometry x="20" y="315" width="300" height="25" as="geometry"/>
        </mxCell>

        <!-- ========================================== -->
        <!-- БЛОК 7: PEX РАЗВОДКА (синий) -->
        <!-- ========================================== -->
        <mxCell id="b7_group" value="" style="group" vertex="1" connectable="0" parent="1">
          <mxGeometry x="1040" y="1050" width="460" height="620" as="geometry"/>
        </mxCell>
        <mxCell id="b7_bg" value="" style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;arcSize=6;" vertex="1" parent="b7_group">
          <mxGeometry width="460" height="620" as="geometry"/>
        </mxCell>
        <mxCell id="b7_title" value="&lt;b&gt;БЛОК 7: ГОРИЗОНТАЛЬНАЯ РАЗВОДКА PEX&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;fontSize=14;fontColor=#1a1a2e;" vertex="1" parent="b7_group">
          <mxGeometry x="10" y="10" width="440" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="b7_diamond" value="Тип разводки?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="b7_group">
          <mxGeometry x="150" y="50" width="150" height="50" as="geometry"/>
        </mxCell>

        <!-- Лучевая -->
        <mxCell id="b7_radial" value="&lt;b&gt;ЛУЧЕВАЯ (radial)&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;b&gt;Внутриквартирные коллекторы:&lt;/b&gt;&lt;br&gt;outputsPerApt = rooms + 1&lt;br&gt;кол-во = apartments × 2&lt;br&gt;фитинги = apartments × outputs × 2&lt;br&gt;&lt;br&gt;&lt;b&gt;Трубы PEX:&lt;/b&gt;&lt;br&gt;• d16: windowCount × 3 м (подводка)&lt;br&gt;• d20: apartments × 5 м (этаж→кв.)&lt;br&gt;• d25: corridorLen × floors × 2&lt;br&gt;  (или manifoldOutputs × floors × 3)" style="rounded=1;whiteSpace=wrap;html=1;align=left;spacingLeft=10;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;" vertex="1" parent="b7_group">
          <mxGeometry x="20" y="120" width="200" height="230" as="geometry"/>
        </mxCell>

        <!-- Попутная -->
        <mxCell id="b7_series" value="&lt;b&gt;ПОПУТНАЯ (series)&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;b&gt;Тройники:&lt;/b&gt;&lt;br&gt;teeCount = (windowCount − apts) × 2&lt;br&gt;• 25×16×20: min(apts×2, total)&lt;br&gt;• 20×16×16: min(apts×2, rest)&lt;br&gt;• 16×16×16: остальные&lt;br&gt;&lt;br&gt;&lt;b&gt;Трубы PEX:&lt;/b&gt;&lt;br&gt;• d16: windowCount × 1.5 м&lt;br&gt;• d20: windowCount × 2.0 м&lt;br&gt;• d25: corridorLen × floors × 2" style="rounded=1;whiteSpace=wrap;html=1;align=left;spacingLeft=10;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;" vertex="1" parent="b7_group">
          <mxGeometry x="240" y="120" width="200" height="230" as="geometry"/>
        </mxCell>

        <!-- Общая длина -->
        <mxCell id="b7_total" value="&lt;b&gt;Общая длина PEX:&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#0000CC&quot;&gt;totalPexLen = pexD16 + pexD20 + pexD25&lt;/font&gt;&lt;br&gt;(может быть переопределена вручную)" style="rounded=1;whiteSpace=wrap;html=1;align=center;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="b7_group">
          <mxGeometry x="20" y="370" width="420" height="60" as="geometry"/>
        </mxCell>

        <!-- Дополнительные PEX -->
        <mxCell id="b7_extra" value="&lt;b&gt;Комплектующие PEX:&lt;/b&gt;&lt;br&gt;• Гофра: totalPexLen × 0.6 (60%)&lt;br&gt;• Изоляция ВПЭ: totalPexLen × 0.4 (40%)&lt;br&gt;• Хомуты: totalPexLen × 2 (2 шт/м.п.)&lt;br&gt;• Муфты: floor(totalPexLen / 200)&lt;br&gt;• Пресс-гильзы: windowCount×2 + муфты" style="rounded=1;whiteSpace=wrap;html=1;align=left;spacingLeft=10;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;" vertex="1" parent="b7_group">
          <mxGeometry x="20" y="445" width="420" height="110" as="geometry"/>
        </mxCell>

        <mxCell id="b7_output" value="&lt;b&gt;ВЫХОД →&lt;/b&gt; pexD16, pexD20, pexD25, totalPexLen, materials[]" style="rounded=1;whiteSpace=wrap;html=1;align=center;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;fontStyle=1;" vertex="1" parent="b7_group">
          <mxGeometry x="20" y="575" width="420" height="30" as="geometry"/>
        </mxCell>

        <!-- ========================================== -->
        <!-- БЛОК 8: ИТОГОВАЯ СМЕТА (серый) -->
        <!-- ========================================== -->
        <mxCell id="b8_group" value="" style="group" vertex="1" connectable="0" parent="1">
          <mxGeometry x="1540" y="1050" width="350" height="340" as="geometry"/>
        </mxCell>
        <mxCell id="b8_bg" value="" style="rounded=1;whiteSpace=wrap;fillColor=#f5f5f5;strokeColor=#666666;arcSize=6;" vertex="1" parent="b8_group">
          <mxGeometry width="350" height="340" as="geometry"/>
        </mxCell>
        <mxCell id="b8_title" value="&lt;b&gt;БЛОК 8: ПНР И ИТОГОВАЯ СМЕТА&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;fontSize=14;fontColor=#1a1a2e;" vertex="1" parent="b8_group">
          <mxGeometry x="10" y="10" width="330" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="b8_pnr" value="&lt;b&gt;Пусконаладочные работы (ПНР):&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#0000CC&quot;&gt;totalPipeLen = totalRiserLen + totalPexLen&lt;/font&gt;&lt;br&gt;&lt;br&gt;• Гидравлич. испытание — totalPipeLen м.п.&lt;br&gt;• Промывка системы — totalPipeLen м.п.&lt;br&gt;• Опробование — totalPipeLen м.п.&lt;br&gt;• Сдача системы — 1 компл." style="rounded=1;whiteSpace=wrap;html=1;align=left;spacingLeft=10;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;" vertex="1" parent="b8_group">
          <mxGeometry x="20" y="50" width="310" height="130" as="geometry"/>
        </mxCell>

        <mxCell id="b8_pricing" value="&lt;b&gt;Ценообразование (3 уровня):&lt;/b&gt;&lt;br&gt;1. Рыночная матрица (price_matrix.json)&lt;br&gt;2. Бренд (brands.json)&lt;br&gt;3. Фиксированная оценка (fixedPrice)&lt;br&gt;&lt;br&gt;&lt;b&gt;Работы:&lt;/b&gt; подрядчик → сосед → матрица" style="rounded=1;whiteSpace=wrap;html=1;align=left;spacingLeft=10;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="b8_group">
          <mxGeometry x="20" y="195" width="310" height="100" as="geometry"/>
        </mxCell>

        <mxCell id="b8_output" value="&lt;b&gt;ВЫХОД →&lt;/b&gt; Итоговая смета (материалы + работы + цены)" style="rounded=1;whiteSpace=wrap;html=1;align=center;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;fontStyle=1;" vertex="1" parent="b8_group">
          <mxGeometry x="20" y="305" width="310" height="25" as="geometry"/>
        </mxCell>

        <!-- ========================================== -->
        <!-- СТРЕЛКИ МЕЖДУ БЛОКАМИ -->
        <!-- ========================================== -->

        <!-- Блок1 → Блок2 -->
        <mxCell id="arrow_1_2" value="windowCount,&lt;br&gt;heatLoad_W, Δt,&lt;br&gt;windows[]" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#0000CC;fontColor=#0000CC;fontSize=9;exitX=1;exitY=0.85;exitDx=0;exitDy=0;entryX=0;entryY=0.1;entryDx=0;entryDy=0;" edge="1" parent="1" source="b1_bg" target="b2_bg">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Блок2 → Блок3 -->
        <mxCell id="arrow_2_3" value="perWindow[],&lt;br&gt;deviceType" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#006600;fontColor=#006600;fontSize=9;exitX=1;exitY=0.15;exitDx=0;exitDy=0;entryX=0;entryY=0.3;entryDx=0;entryDy=0;" edge="1" parent="1" source="b2_bg" target="b3_bg">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Блок3 → Блок4 -->
        <mxCell id="arrow_3_4" value="thermoHead,&lt;br&gt;valve" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#CC0000;fontColor=#CC0000;fontSize=9;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="b3_bg" target="b4_bg">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Блок1 → Блок5 -->
        <mxCell id="arrow_1_5" value="heatLoad_W,&lt;br&gt;riserPairs,&lt;br&gt;heatingZones,&lt;br&gt;numFloors" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#CC0000;fontColor=#CC0000;fontSize=9;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="b1_bg" target="b5_bg">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Блок5 → Блок6 -->
        <mxCell id="arrow_5_6" value="riserDN,&lt;br&gt;totalRiserLen" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#9673a6;fontColor=#9673a6;fontSize=9;exitX=1;exitY=0.7;exitDx=0;exitDy=0;entryX=0;entryY=0.3;entryDx=0;entryDy=0;" edge="1" parent="1" source="b5_bg" target="b6_bg">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Блок6 → Блок7 -->
        <mxCell id="arrow_6_7" value="manifolds" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#6c8ebf;fontColor=#6c8ebf;fontSize=9;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.3;entryDx=0;entryDy=0;" edge="1" parent="1" source="b6_bg" target="b7_bg">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Блок7 → Блок8 -->
        <mxCell id="arrow_7_8" value="totalPexLen,&lt;br&gt;materials[]" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#666666;fontColor=#666666;fontSize=9;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="b7_bg" target="b8_bg">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Блок4 → Блок8 (specData) -->
        <mxCell id="arrow_4_8" value="specData[]" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#666666;fontColor=#666666;fontSize=9;dashed=1;exitX=1;exitY=0.8;exitDx=0;exitDy=0;entryX=1;entryY=0.2;entryDx=0;entryDy=0;" edge="1" parent="1" source="b4_bg" target="b8_bg">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ========================================== -->
        <!-- ЛЕГЕНДА -->
        <!-- ========================================== -->
        <mxCell id="legend_bg" value="" style="rounded=1;whiteSpace=wrap;fillColor=#ffffff;strokeColor=#333333;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="40" y="1440" width="580" height="200" as="geometry"/>
        </mxCell>
        <mxCell id="legend_title" value="&lt;b&gt;ЛЕГЕНДА&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;fontSize=13;fontColor=#1a1a2e;" vertex="1" parent="1">
          <mxGeometry x="250" y="1450" width="160" height="25" as="geometry"/>
        </mxCell>

        <mxCell id="leg1" value="" style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="60" y="1485" width="30" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="leg1t" value="Исходные данные / PEX" style="text;html=1;align=left;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="100" y="1483" width="200" height="24" as="geometry"/>
        </mxCell>

        <mxCell id="leg2" value="" style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="60" y="1515" width="30" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="leg2t" value="Подбор приборов / ветвления" style="text;html=1;align=left;fontSize=11;" vertex="1" parent="1">
